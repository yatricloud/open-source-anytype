{
	"name": "anytype",
	"version": "0.55.20-alpha",
	"description": "Anytype",
	"main": "electron.js",
	"scripts": {
		"precommit": "bunx lint-staged",
		"typecheck": "bunx tsc --noEmit -p tsconfig.json && bunx tsc --noEmit -p tsconfig.electron.json",
		"lint": "bunx biome lint src/ && eslint .",
		"lint:fix": "bunx biome check --write src/",
		"format": "bunx biome format --write src/",
		"format:check": "bunx biome format src/",
		"release:notes": "node scripts/generate-release-notes.js",
		"electron": "bunx electron .",
		"electron-win": "bunx electron.cmd .",
		"start:watch": "cross-env-shell vite --config vite.config.ts --port ${SERVER_PORT:-8080}",
		"start:electron-wait-vite": "cross-env-shell node scripts/wait-for-localhost.js ${SERVER_PORT:-8080} && bun run electron",
		"start:electron-wait-vite-win": "cross-env-shell node scripts/wait-for-localhost.js ${SERVER_PORT:-8080} && bun run electron-win",
		"start:dev": "node scripts/build-electron.js && node scripts/start-dev.js",
		"start:dev-win": "node scripts/build-electron.js && node scripts/start-dev.js",
		"build:electron": "node scripts/build-electron.js",
		"watch:electron": "node scripts/build-electron.js --watch",
		"build": "node scripts/build-electron.js && vite build --config vite.config.ts",
		"build:dev": "node scripts/build-electron.js && vite build --config vite.config.ts --mode development",
		"build:ext": "vite build --config vite.extension.config.ts",
		"build:deps": "node scripts/analyze-deps.js",
		"build:nmh": "go build -o dist/nativeMessagingHost ./go/nativeMessagingHost.go",
		"build:nmh-win": "go build -o dist/nativeMessagingHost.exe ./go/nativeMessagingHost.go",
		"build:pixi": "vite build --config vite.worker.config.ts",
		"generate:icons": "bun scripts/convert-icons.ts",
		"generate:protos": "bash scripts/generate-protos.sh",
		"dist:mac": "bun run build:electron && bun run build:deps && vite build --config vite.config.ts && DATE=`date '+%Y-%m-%d_%H_%M'` GIT_COMMIT=`git rev-parse --short HEAD` electron-builder --macos --arm64 --x64",
		"dist:macarm": "bun run build:electron && bun run build:deps && vite build --config vite.config.ts && DATE=`date '+%Y-%m-%d_%H_%M'` GIT_COMMIT=`git rev-parse --short HEAD` electron-builder --macos --arm64",
		"dist:macamd": "bun run build:electron && bun run build:deps && vite build --config vite.config.ts && DATE=`date '+%Y-%m-%d_%H_%M'` GIT_COMMIT=`git rev-parse --short HEAD` electron-builder --macos --x64",
		"dist:win": "bun run build:electron && bun run build:deps && vite build --config vite.config.ts && electron-builder --windows",
		"dist:linux": "bun run build:electron && bun run build:deps && vite build --config vite.config.ts && DATE=`date '+%Y-%m-%d_%H_%M'` GIT_COMMIT=`git rev-parse --short HEAD` electron-builder --linux --arm64 --x64",
		"dist:linuxamd": "bun run build:electron && bun run build:deps && vite build --config vite.config.ts && DATE=`date '+%Y-%m-%d_%H_%M'` GIT_COMMIT=`git rev-parse --short HEAD` electron-builder --linux --x64",
		"dist:linuxamd-appimage": "bun run build:electron && bun run build:deps && vite build --config vite.config.ts && DATE=`date '+%Y-%m-%d_%H_%M'` GIT_COMMIT=`git rev-parse --short HEAD` electron-builder --linux appImage --x64",
		"dist:linuxarm": "bun run build:electron && bun run build:deps && vite build --config vite.config.ts && DATE=`date '+%Y-%m-%d_%H_%M'` GIT_COMMIT=`git rev-parse --short HEAD` electron-builder --linux --arm64",
		"dist:linuxarm-appimage": "bun run build:electron && bun run build:deps && vite build --config vite.config.ts && DATE=`date '+%Y-%m-%d_%H_%M'` GIT_COMMIT=`git rev-parse --short HEAD` electron-builder --linux appImage --arm64",
		"publish:mac": "bun run build:electron && vite build --config vite.config.ts && DATE=`date '+%Y-%m-%d_%H_%M'` GIT_COMMIT=`git rev-parse --short HEAD` BUILD_NUMBER=`git rev-parse --short HEAD` electron-builder --macos --publish  always",
		"publish:linux": "bun run build:electron && vite build --config vite.config.ts && DATE=`date '+%Y-%m-%d_%H_%M'` GIT_COMMIT=`git rev-parse --short HEAD` BUILD_NUMBER=`git rev-parse --short HEAD` electron-builder --linux --publish  always",
		"publish:win": "bun run build:electron && vite build --config vite.config.ts && DATE=`date '+%Y-%m-%d_%H_%M'` GIT_COMMIT=`git rev-parse --short HEAD` BUILD_NUMBER=`git rev-parse --short HEAD` electron-builder --windows --publish  always",
		"postinstall": "bunx patch-package && electron-builder install-app-deps",
		"prepare": "husky install",
		"update:locale": "node ./electron/hook/locale.js",
		"ext:manifest:firefox": "node electron/hook/switch-manifest.js firefox",
		"ext:manifest:chromium": "node electron/hook/switch-manifest.js chromium",
		"start:web": "node scripts/start-web.js",
		"start:dev-web": "cross-env WEB_OPEN_BROWSER=1 node scripts/start-web.js",
		"build:web": "vite build --config vite.web.config.ts",
		"test": "vitest run",
		"test:watch": "vitest",
		"storybook": "storybook dev -p 6006",
		"storybook:build": "storybook build"
	},
